## Core
NEXT_PUBLIC_APP_NAME="StreamCore"
# Public site URL (https://your-domain.com, no trailing slash). Used for Twitch embed `parent=` params.
# For ngrok: set this to your tunnel URL AND set AUTH_URL to the same origin (Twitch OAuth redirect).
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# Live dashboard Twitch chat: omit or "embed" (default, typing works). Use "popout" only if you accept iframe limits.
# NEXT_PUBLIC_TWITCH_CHAT_MODE="embed"

## Auth.js (NextAuth v5)
# REQUIRED on Vercel / any production host. If missing or empty → users see `/api/auth/error?error=Configuration`.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# Legacy alias — Auth reads this if AUTH_SECRET is unset (see auth.ts).
# NEXTAUTH_SECRET="same-as-above-or-leave-empty"
#
# Canonical public URL visitors use — must match your Twitch Redirect URI origin exactly
# (https only in prod; no trailing slash). v5 prefers AUTH_URL; NEXTAUTH_URL still works.
#
AUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_URL="https://your-app.vercel.app"
#
# auth.config.ts sets trustHost so OAuth works behind reverse proxies / non-Vercel hosts.
# If callbacks still fail, double-check AUTH_URL matches the domain in the Twitch Redirect URL.
#
# Local ngrok / preview: if this file sets AUTH_URL to production but you browse via another host
# (e.g. *.ngrok-free.dev), OAuth can break. Either unset AUTH_URL locally, or set:
# AUTH_PUBLIC_URL_MODE=dynamic
# so `/api/auth/*` uses the browser's actual origin for the OAuth handshake (see `app/api/auth/[...nextauth]/route.ts`).

# Verbose Auth.js logs in server output (use on Vercel for one reproduction, then turn off).
# AUTH_DEBUG="true"

# Enable GET https://YOUR_HOST/api/debug/auth in production temporarily (shows booleans only, never secrets).
# AUTH_DIAG="1"

## Database (PostgreSQL / Supabase)
#
# Supabase: Project Settings → Database → Connection string (URI). Use Postgres, not the https:// API URL.
# If Prisma can't reach `db.<ref>.supabase.co:5432`, prefer the Transaction pooler (often port 6543)
# with `pgbouncer=true` on the connection string — see Supabase “Connect to Postgres” docs.
#
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:PASSWORD@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# REQUIRED for Prisma Migrate (`db:migrate:deploy`): transaction pool (:6543) often hangs migrations.
# In Supabase → Database → Connection string, copy the "Session pooler" URI (port 5432, same *.pooler host).
# If your network blocks `db.<ref>.supabase.co`, session pooler still works for many setups.
#
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:PASSWORD@aws-0-<REGION>.pooler.supabase.com:5432/postgres"
#
# Prisma CLI loads `.env` then `.env.local` via scripts/prisma-env.mjs.
#
# If you only put DATABASE_URL / DIRECT_URL in `.env.local`, do NOT run `npx prisma migrate` directly —
# Prisma only auto-loads `.env`, so you will get P1012 "DIRECT_URL not found". Use:
#   npm run db:migrate | db:push | db:generate | db:migrate:deploy | db:studio
# or: node scripts/prisma-env.mjs migrate dev
# For raw `npx prisma`, copy the same two vars into `.env` as well.

## Optional: analytics snapshot cron (Helix + DB)
# Shared secret for GET /api/cron/analytics-snapshots (Authorization: Bearer … or ?secret=)
# CRON_SECRET="openssl-rand-hex-32"
#
# Register Twitch HTTP EventSub stream.online / stream.offline against POST /api/webhooks/twitch
# (see TWITCH_EVENTSUB_WEBHOOK_SECRET below) so open broadcast sessions drive the snapshot cron.

## Twitch OAuth
TWITCH_CLIENT_ID="replace-me"
TWITCH_CLIENT_SECRET="replace-me"
#
# Optional: HTTP EventSub webhook secret (must match the secret on each EventSub subscription using
# transport "webhook" → `POST /api/webhooks/twitch`). Local dev usually uses WS ingest instead
# (`/api/twitch/channel-redemptions/ingest` from the live dashboard).
# TWITCH_EVENTSUB_WEBHOOK_SECRET="openssl-rand-hex-32"
#
# Twitch Developer Console → Your app → Redirect URLs MUST include exactly:
#   {AUTH_URL}/api/auth/callback/twitch
# Add both www and non-www variants if you use both.

## StreamCore IRC worker (optional — `node scripts/streamcore-bot-irc.mjs`)
# STREAMCORE_BOT_IDENTITY_MODE="helper"   # helper | broadcaster
# STREAMCORE_BOT_CHANNEL="your_broadcaster_login"
# STREAMCORE_BOT_TWITCH_USERNAME="StreamCoreHelper"
# helper mode:
# STREAMCORE_HELPER_TOKEN="oauth:…"
# broadcaster mode:
# USER_OAUTH_TOKEN="oauth:…"
# Legacy alias:
# STREAMCORE_BOT_TWITCH_OAUTH="oauth:…"

## Spotify OAuth
SPOTIFY_CLIENT_ID="replace-me"
SPOTIFY_CLIENT_SECRET="replace-me"
# Optional Auth.js aliases (same values as above). If set, they override empty `SPOTIFY_*` when the
# Spotify entry is built as a provider factory in `auth.config.ts`.
# AUTH_SPOTIFY_ID="replace-me"
# AUTH_SPOTIFY_SECRET="replace-me"

