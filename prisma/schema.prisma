generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App / Prisma Client (e.g. transaction pooler :6543 + pgbouncer=true) — see `lib/prisma.ts` runtime URL tweaks
  url       = env("DATABASE_URL")
  // Prisma Migrate — session/direct URI; avoid transaction pooler for migrations (see `.env.example`)
  directUrl = env("DIRECT_URL")
}

// Auth.js / NextAuth.js recommended Prisma schema
// https://authjs.dev/reference/adapter/prisma
model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  consents      UserConsent[]
  channelPerms  ChannelPermission[]
  invitesCreated PermissionInvite[] @relation("PermissionInviteCreatedBy")
  dashboardLayouts DashboardLayout[]
  songRequestConfigs SongRequestConfig[]
  botCommands      BotCommand[]
  botSettings      BotSettings[]

  /** Daily rollups from Twitch CSV exports + manual backfill. */
  channelAnalyticsSummaries ChannelAnalyticsSummary[]
  /** 5-minute live audience + chat velocity samples while a session is active. */
  streamSnapshots           StreamSnapshot[]
  /** One open row per broadcaster while EventSub reports the channel live. */
  liveBroadcastSessions     LiveBroadcastSession[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

/**
 * One row per calendar day per user — populated from Twitch Channel Analytics CSV imports
 * and/or future nightly aggregation jobs. Powers KPI cards + day-resolution charts.
 */
model ChannelAnalyticsSummary {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @db.Date
  avgViewers       Float    @default(0)
  maxViewers       Int      @default(0)
  follows          Int      @default(0)
  subs             Int      @default(0)
  revenue          Float    @default(0)
  minutesStreamed  Int      @default(0)
  liveViews        Int      @default(0)
  uniqueChatters   Int      @default(0)
  clipsCreated     Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

/**
 * Fine-grained samples (cron / worker every ~5 min while live). Merged into charts when
 * daily summaries are missing for that period.
 */
model StreamSnapshot {
  id                  String   @id @default(cuid())
  userId              String
  channelTwitchId     String
  timestamp           DateTime
  currentViewers      Int      @default(0)
  messagesPerMinute   Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([channelTwitchId, timestamp])
}

/**
 * Tracks an active go-live window for cron-based Helix polling. Opened on `stream.online`,
 * closed on `stream.offline`.
 */
model LiveBroadcastSession {
  id                  String    @id @default(cuid())
  userId              String
  channelTwitchId     String
  startedAt           DateTime
  endedAt             DateTime?
  lastSnapshotAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt])
  @@index([channelTwitchId, startedAt])
}

model DashboardLayout {
  id              String   @id @default(cuid())
  userId          String
  channelTwitchId String
  layoutsJson     String
  visibleJson     String
  /** JSON: Partial<Record<dockKey, boolean>> — true = dock locked (not draggable/resizable) */
  docksLockedJson String   @default("{}")
  /** Pack docks vertically (react-grid-layout compact) for edge-to-edge rows with fewer gaps. */
  fillDashboardRowGaps Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelTwitchId])
  @@index([channelTwitchId])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserConsent {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  scopes    String
  grantedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
}

enum PermissionRole {
  BASIC_EDITOR
  EDITOR
  FULL_CONTROL
}

model ChannelPermission {
  id                 String          @id @default(cuid())
  userId             String
  // The Twitch broadcaster channel this permission grants access to.
  channelTwitchId    String
  channelDisplayName String
  role               PermissionRole

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([userId, channelTwitchId])
  @@index([channelTwitchId])
}

/**
 * Persistent archive of every Twitch IRC chat message we observe via the dashboard's WebSocket
 * client. Twitch does not expose a "messages by user" API, so the only way to render history in
 * the user-profile popover across sessions / devices / hot reloads is to write each PRIVMSG into
 * our own DB as it arrives.
 *
 * Access policy:
 *   - Writes: any user who has access to the channel (self or `ChannelPermission`) — the rows
 *     are owned by the channel, not the writer, so multiple moderators converge on a single log.
 *   - Reads: same — the user-profile popover queries by `userTwitchId` or `userLogin`.
 *   - There is no per-user PII expectation here that isn't already public in the broadcaster's
 *     own Twitch chat moderation tools.
 *
 * Soft delete (`deletedAt`) is used for CLEARMSG / CLEARCHAT so moderators can still audit what
 * was removed; the query API can be told whether to include or hide soft-deleted rows.
 */
model ChatMessageArchive {
  id              String    @id @default(cuid())
  /** The broadcaster whose chat this message was observed in. */
  channelTwitchId String
  /** Twitch IRC `id` tag — globally unique per delivered PRIVMSG; basis of dedupe on ingest. */
  ircId           String
  /** Twitch numeric user-id (`user-id` tag). Optional only for legacy rows. */
  userTwitchId    String?
  /** Lowercase IRC nick. Always indexed for popover lookups. */
  userLogin       String
  displayName     String
  color           String?
  text            String
  /** Raw `badges` IRC tag (`subscriber/24,moderator/1,...`). */
  badges          String?
  /** Twitch `tmi-sent-ts` (epoch ms). Stored as BigInt to outlive `Number.MAX_SAFE_INTEGER`. */
  ts              BigInt
  isMod           Boolean   @default(false)
  isSubscriber    Boolean   @default(false)
  /** Populated when CLEARMSG / CLEARCHAT removed this row from live chat. */
  deletedAt       DateTime?

  createdAt       DateTime  @default(now())

  @@unique([channelTwitchId, ircId])
  @@index([channelTwitchId, userTwitchId, ts])
  @@index([channelTwitchId, userLogin, ts])
  @@index([channelTwitchId, ts])
}

/**
 * Channel point redemptions (EventSub → DB). `twitchRedemptionId` is Twitch’s redemption id for Helix.
 */
model ChannelRedemption {
  id                  String   @id @default(uuid())
  twitchRedemptionId  String   @unique
  channelTwitchId     String
  rewardId            String
  userName            String   @map("user_name")
  userLogin           String?  @map("user_login")
  rewardTitle         String   @map("reward_title")
  userInput           String?  @map("user_input")
  cost                Int      @default(0)
  status              String   @default("UNFULFILLED") @map("status")
  redeemedAt          DateTime? @map("redeemed_at")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([channelTwitchId, status])
  @@map("channel_redemptions")
}

model PermissionInvite {
  id                 String          @id @default(cuid())
  token              String          @unique
  // Channel the invite is for
  channelTwitchId    String
  channelDisplayName String
  role               PermissionRole
  createdByUserId    String
  usedByUserId       String?
  usedAt             DateTime?
  expiresAt          DateTime?

  createdBy          User            @relation("PermissionInviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([channelTwitchId])
  @@index([token])
}

/**
 * Per-channel song request settings (queue rules + optional Channel Points reward id).
 * One row per broadcaster channel the user owns.
 */
model SongRequestConfig {
  id                    String   @id @default(cuid())
  userId                String
  channelTwitchId       String   @unique
  allowEveryone         Boolean  @default(true)
  subsOnly              Boolean  @default(false)
  vipsOnly              Boolean  @default(false)
  modsOnly              Boolean  @default(false)
  /** Same role-gate pattern as song requests, applied to the built-in `!volume` command only. */
  volumeAllowEveryone   Boolean  @default(true)
  volumeSubsOnly        Boolean  @default(false)
  volumeVipsOnly        Boolean  @default(false)
  volumeModsOnly        Boolean  @default(false)
  /** Twitch custom reward id for song requests (Helix). */
  channelPointsRewardId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SongRequestQueueItem {
  id                 String   @id @default(cuid())
  channelTwitchId    String
  title              String
  artist             String
  spotifyUri         String
  requestedByLogin   String
  createdAt          DateTime @default(now())

  @@index([channelTwitchId, createdAt])
}

/**
 * Per-broadcaster bot command definitions (StreamCoreHelper).
 *
 * `response` is a chat-message template that supports inline variables resolved by the bot
 * runtime at trigger time: ${user}, ${target}, ${random:min-max}, ${streamer}.
 */
model BotCommand {
  id              String   @id @default(cuid())
  userId          String
  channelTwitchId String
  trigger         String
  response        String
  enabled         Boolean  @default(true)
  cooldownSec     Int      @default(5)
  modOnly         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelTwitchId, trigger])
  @@index([userId])
  @@index([channelTwitchId])
}

/**
 * Per-broadcaster bot runtime settings (one row per channel).
 *
 * `prefix` is the trigger prefix the bot listens for (default `!`). `enabled` is the master
 * on/off switch for the channel.
 */
model BotSettings {
  id              String   @id @default(cuid())
  userId          String
  channelTwitchId String   @unique
  enabled         Boolean  @default(true)
  prefix          String   @default("!")
  /**
   * When false (default), command and greeting lines are prefixed with `StreamCoreHelper · ` before sending.
   * When true, lines are sent raw (still via your Twitch IRC session) so they read like normal broadcaster chat.
   */
  prefixRepliesAsHelper Boolean @default(false)
  greetingEnabled Boolean  @default(false)
  greetingMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

